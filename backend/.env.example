# Server configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=civitrack_jwt_secret_token_key_2026_production_ready!

# Database connection (Leave empty to use local JSON file fallback database)
MONGODB_URI=

# Cloudinary credentials (Leave empty to use local filesystem storage upload fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini API key (Leave empty to use local rule-based issue classifier fallback)
GEMINI_API_KEY=
